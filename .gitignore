# .gitignore
# Global Git ignore rules for decoryou project

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
.env.production.local
.env.test.local
!.env.example

# ============================================================================
# TERRAFORM
# ============================================================================
terraform.tfstate
terraform.tfstate.backup
.terraform/
terraform.tfvars
*.tfvars
!terraform.tfvars.example

# ============================================================================
# AWS CREDENTIALS
# ============================================================================
.aws/
credentials
config
*.pem
*.key
*.p12
*.pfx

# ============================================================================
# ANSIBLE
# ============================================================================
vault_pass.txt
ansible.cfg
inventory/
!inventory.example/

# ============================================================================
# DOCKER
# ============================================================================
.docker/
config.json

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Python
venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/
.ionide/

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
dist/
build/
coverage/
.nyc_output/
out/

# ============================================================================
# TERRAFORM
# ============================================================================
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*
*.tfvars
crash.log
override.tf

# ============================================================================
# ANSIBLE
# ============================================================================
*.retry
ansible/*.retry

# ============================================================================
# DOCKER
# ============================================================================
.dockerignore
docker-compose.prod.yml

# ============================================================================
# LOGS
# ============================================================================
logs/
*.log
*.log.*

# ============================================================================
# TEMPORARY FILES
# ============================================================================
.tmp/
temp/
*.tmp

# ============================================================================
# OS FILES
# ============================================================================
.DS_Store
Thumbs.db
*.exe
*.dmg

# ============================================================================
# TEST COVERAGE
# ============================================================================
coverage/
.coverage
htmlcov/

# ============================================================================
# JENKINS
# ============================================================================
jenkins/*.tfplan*
jenkins/tfplan.*/

# ============================================================================
# MONITORING
# ============================================================================
prometheus-data/
grafana-data/

# ============================================================================
# KEEP SOME FILES EXPLICITLY
# ============================================================================
!.gitkeep
!.github/
!.env.example