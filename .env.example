# Environment Configuration - Development
# ⚠️  IMPORTANT: Never commit .env with real values
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME=decoryou
APP_ENVIRONMENT=development
APP_PORT=8080
LOG_LEVEL=debug
NODE_ENV=development

# ============================================================================
# DATABASE
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=decoryou_dev
DB_USER=decoryou
DB_PASSWORD=change_me_in_dev
DATABASE_URL=mysql://decoryou:change_me_in_dev@localhost:3306/decoryou_dev

# ============================================================================
# REDIS CACHE
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_value_here
AWS_SECRET_ACCESS_KEY=your_value_here
AWS_ACCOUNT_ID=your_value_here

# S3 Configuration
S3_BUCKET=decoryou-dev-bucket
S3_REGION=us-east-1
S3_ACL=private

# ============================================================================
# MINIO (Local S3-compatible storage)
# ============================================================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_value_here
MINIO_SECRET_KEY=your_value_here
MINIO_BUCKET=decoryou

# ============================================================================
# MONITORING
# ============================================================================
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_PASSWORD=admin

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
SESSION_SECRET=your_session_secret_change_me
ENCRYPTION_KEY=your_encryption_key_change_me

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@decoryou.com

# ============================================================================
# API KEYS
# ============================================================================
API_KEY_SECRET=your_api_key_secret
EXTERNAL_API_KEY=your_external_api_key

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_ANALYTICS=true
FEATURE_NOTIFICATIONS=true
FEATURE_ADVANCED_REPORTING=false

# ============================================================================
# DEPLOYMENT
# ============================================================================
DEPLOYMENT_VERSION=latest
DEPLOYMENT_TIMESTAMP=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
