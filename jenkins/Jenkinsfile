pipeline {
    agent any

    environment {
        AWS_REGION = 'us-east-1' 
        APP_NAME   = 'decoryou'
        TF_IN_AUTOMATION = 'true'
    }

    stages {
        stage('Initialize & AWS Identity') {
            steps {
                // Используем твои ключи 'my-aws-key'
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'my-aws-key',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    script {
                        echo "🔍 Идентификация в AWS..."
                        env.AWS_ACCOUNT_ID = sh(script: "aws sts get-caller-identity --query Account --output text", returnStdout: true).trim()
                        env.DOCKER_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
                        env.DOCKER_IMAGE_NAME = "${env.DOCKER_REGISTRY}/${env.APP_NAME}"
                        echo "✅ Аккаунт: ${env.AWS_ACCOUNT_ID}"
                    }
                }
            }
        }

        stage('Quality & Security Gate') {
            parallel {
                stage('Terraform Lint') {
                    steps {
                        echo "Проверка синтаксиса Terraform..."
                        // Если папка terraform есть, проверяем её
                        sh 'terraform -chdir=terraform fmt -check || echo "Пропустить линт"'
                    }
                }
                stage('Docker Lint') {
                    steps {
                        echo "Проверка Dockerfile..."
                        // Проверь, где лежит Dockerfile. Если в корне, то просто '.'
                        sh 'docker run --rm -i hadolint/hadolint < Dockerfile || echo "Hadolint не найден, пропускаем"'
                    }
                }
            }
        }

        stage('Build & Push to ECR') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'my-aws-key']]) {
                    script {
                        echo "🐳 Сборка образа ${env.DOCKER_IMAGE_NAME}..."
                        // Логин в ECR
                        sh "aws ecr get-login-password --region ${env.AWS_REGION} | docker login --username AWS --password-stdin ${env.DOCKER_REGISTRY}"
                        
                        // Сборка (убедись, что Dockerfile в корне проекта)
                        sh "docker build -t ${env.DOCKER_IMAGE_NAME}:${env.BUILD_NUMBER} -t ${env.DOCKER_IMAGE_NAME}:latest ."
                        
                        // Пуш в облако
                        sh "docker push ${env.DOCKER_IMAGE_NAME}:${env.BUILD_NUMBER}"
                        sh "docker push ${env.DOCKER_IMAGE_NAME}:latest"
                    }
                }
            }
        }

        stage('Terraform Plan & Apply') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'my-aws-key']]) {
                    sh '''
                        cd terraform
                        terraform init
                        terraform plan -out=tfplan
                        terraform apply -auto-approve tfplan
                    '''
                }
            }
        }
    }

    post {
        always {
            cleanWs()
            echo "🧹 Очистка рабочего пространства завершена."
        }
        success {
            echo "🚀 ПРОДАКШН ГОТОВ! Сайт decoryou должен быть доступен."
        }
    }
}