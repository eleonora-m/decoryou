pipeline {
    agent any

    environment {
        // Базовые настройки (НЕ секретные)
        AWS_REGION = 'us-east-1' 
        APP_NAME   = 'decoryou'
        
        // Переменные для Terraform
        TF_IN_AUTOMATION = 'true'
        TF_INPUT         = 'false'
        
        // Секреты Jenkins (Спрашиваем только их)
        SLACK_WEBHOOK = credentials('slack-webhook-url')
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 1, unit: 'HOURS')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Initialize & AWS Identity') {
            steps {
                script {
                    echo "🔍 Идентификация AWS через IAM Role..."
                    // Динамически получаем Account ID, чтобы не хранить его в коде
                    env.AWS_ACCOUNT_ID = sh(
                        script: "aws sts get-caller-identity --query Account --output text",
                        returnStdout: true
                    ).trim()
                    
                    env.DOCKER_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
                    env.DOCKER_IMAGE_NAME = "${env.DOCKER_REGISTRY}/${env.APP_NAME}"
                    
                    echo "✅ Аккаунт: ${env.AWS_ACCOUNT_ID}"
                    echo "✅ Образ: ${env.DOCKER_IMAGE_NAME}:${env.BUILD_NUMBER}"
                }
                checkout scm
            }
        }

        stage('Quality & Security Gate') {
            parallel {
                stage('Terraform Lint') {
                    agent { docker { image 'hashicorp/terraform:1.7.0' } }
                    steps {
                        sh 'cd terraform && terraform fmt -check -recursive'
                    }
                }
                stage('Security Scan (tfsec)') {
                    steps {
                        // Запуск через временный контейнер для чистоты системы
                        sh 'docker run --rm -v ${WORKSPACE}/terraform:/src aquasec/tfsec /src || true'
                    }
                }
                stage('Docker Lint (Hadolint)') {
                    steps {
                        sh 'docker run --rm -i hadolint/hadolint < docker/Dockerfile || true'
                    }
                }
            }
        }

        stage('Build & Push to ECR') {
            when { 
                anyOf { branch 'main'; branch 'staging'; branch 'develop' } 
            }
            steps {
                script {
                    echo "🐳 Сборка и отправка образа в ECR..."
                    // Логин в ECR через IAM Role (без ключей!)
                    sh "aws ecr get-login-password --region ${env.AWS_REGION} | docker login --username AWS --password-stdin ${env.DOCKER_REGISTRY}"
                    
                    // Сборка с несколькими тегами
                    sh """
                        docker build -f docker/Dockerfile \
                            -t ${env.DOCKER_IMAGE_NAME}:${env.BUILD_NUMBER} \
                            -t ${env.DOCKER_IMAGE_NAME}:latest .
                    """
                    sh "docker push ${env.DOCKER_IMAGE_NAME}:${env.BUILD_NUMBER}"
                    sh "docker push ${env.DOCKER_IMAGE_NAME}:latest"
                }
            }
        }

        stage('Terraform Plan') {
            agent { docker { image 'hashicorp/terraform:1.7.0' } }
            steps {
                script {
                    def envTag = env.BRANCH_NAME == 'main' ? 'prod' : 'dev'
                    sh """
                        cd terraform
                        terraform init -backend-config="region=${env.AWS_REGION}"
                        terraform plan -var="app_version=${env.BUILD_NUMBER}" -out=tfplan
                    """
                }
            }
        }

        stage('Ansible Deploy') {
            // Только если включен параметр DEPLOY_ENABLED или это ветка main
            when { branch 'main' }
            steps {
                script {
                    def environment = 'prod'
                    echo "📦 Деплой через Ansible в ${environment}..."
                    
                    withCredentials([
                        file(credentialsId: "ansible-vault-${environment}", variable: 'VAULT_FILE'),
                        sshUserPrivateKey(credentialsId: "ansible-ssh-key-${environment}", keyFileVariable: 'SSH_KEY')
                    ]) {
                        sh """
                            export ANSIBLE_HOST_KEY_CHECKING=False
                            ansible-playbook -i ansible/inventories/${environment}/hosts \
                                --private-key \${SSH_KEY} \
                                --vault-password-file \${VAULT_FILE} \
                                -e "docker_image=${env.DOCKER_IMAGE_NAME}:${env.BUILD_NUMBER}" \
                                ansible/site.yml
                        """
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                echo "🔥 Проверка работоспособности приложения..."
                sh "chmod +x jenkins/scripts/smoke-test.sh"
                sh "./jenkins/scripts/smoke-test.sh"
            }
        }
    }

    post {
        success {
            script {
                sh """
                curl -X POST -H 'Content-type: application/json' \
                --data '{"text":"✅ *Success:* ${env.JOB_NAME} [${env.BUILD_NUMBER}]\\nBranch: ${env.BRANCH_NAME}"}' \
                ${env.SLACK_WEBHOOK}
                """
            }
        }
        failure {
            script {
                sh """
                curl -X POST -H 'Content-type: application/json' \
                --data '{"text":"❌ *Failed:* ${env.JOB_NAME} [${env.BUILD_NUMBER}]\\nCheck logs immediately!"}' \
                ${env.SLACK_WEBHOOK}
                """
            }
        }
        always {
            cleanWs()
            echo "🧹 Workspace cleaned."
        }
    }
}