pipeline {
    agent any // Используем основной агент, чтобы иметь доступ к Docker и AWS CLI

    environment {
        // Конфигурация AWS (Указываем явно, так как это не секреты)
        AWS_REGION = 'us-east-1' 
        AWS_ACCOUNT_ID = '123456789012' // Замените на ваш реальный ID
        
        APP_NAME = 'decoryou'
        DOCKER_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        DOCKER_IMAGE_NAME = "${DOCKER_REGISTRY}/${APP_NAME}"
        ECR_REPO_NAME = 'decoryou'
        
        // Terraform
        TF_INPUT = 'false'
        TF_IN_AUTOMATION = 'true'
        
        // Slack - Оставляем в credentials, так как это защищенный URL
        SLACK_WEBHOOK = credentials('slack-webhook-url')
    }

    stages {
        stage('Initialize') {
            steps {
                script {
                    echo "🚀 Starting pipeline for ${APP_NAME}"
                    // Проверка наличия роли (опционально)
                    sh 'aws sts get-caller-identity'
                }
            }
        }

        stage('Prepare & Lint') {
            parallel {
                stage('Terraform Check') {
                    agent { docker { image 'hashicorp/terraform:1.7.0' } }
                    steps {
                        sh 'cd terraform && terraform fmt -check -recursive'
                    }
                }
                stage('Docker Lint') {
                    steps {
                        // Используем hadolint через docker для чистоты
                        sh 'docker run --rm -v ${WORKSPACE}/docker/Dockerfile:/Dockerfile hadolint/hadolint hadolint /Dockerfile || true'
                    }
                }
            }
        }

        stage('Security Scan') {
            parallel {
                stage('tfsec') {
                    steps {
                        // Запуск сканера безопасности
                        sh 'docker run --rm -v ${WORKSPACE}/terraform:/src aquasec/tfsec /src'
                    }
                }
                stage('Checkov') {
                    steps {
                        sh 'docker run --rm -v ${WORKSPACE}/terraform:/tf bridgecrew/checkov -d /tf || true'
                    }
                }
            }
        }

        stage('Build & Push to ECR') {
            when { branch 'main' }
            steps {
                script {
                    // Используем IAM Role инстанса для логина в ECR
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${DOCKER_REGISTRY}"
                    sh "docker build -f docker/Dockerfile -t ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER} ."
                    sh "docker push ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                }
            }
        }

        stage('Deploy to Staging') {
            when { branch 'staging' }
            steps {
                // Здесь будет ваш Terraform Apply
                echo "Deploying to Staging..."
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}